# Copy to .env and fill in. .env is gitignored.

# --- Required ---
ANTHROPIC_API_KEY=
TAVILY_API_KEY=            # app.tavily.com — free tier: 1,000 credits/month

# --- Optional ---
# Provider-prefixed chat model for both stages (default: anthropic:claude-opus-4-8).
# Any LangChain provider works; install the matching extra + set its key (see
# the README "Using a different model"). Examples:
#   RESEARCH_MODEL=openai:gpt-4.1                  # uv sync --extra openai,  OPENAI_API_KEY
#   RESEARCH_MODEL=google_genai:gemini-2.5-pro     # uv sync --extra google,  GOOGLE_API_KEY
#   RESEARCH_MODEL=ollama:llama3.1                 # uv sync --extra ollama,  local, no key
# RESEARCH_MODEL=anthropic:claude-opus-4-8
# RESEARCH_MAX_TOKENS=8000
# RESEARCH_TIMEOUT=300
# RESEARCH_TEMPERATURE=0.2

# Where file-sink drafts are written (default: output/).
# OUTPUT_DIR=output

# IANA timezone for resolving dated prompt files (prompts/YYYY-MM-DD.md).
# PROMPT_TZ=UTC

# --- Optional: publish to an HTTP backend instead of writing files ---
# Set BOTH to POST each finished draft to your own endpoint with a bearer
# token, rather than writing it to OUTPUT_DIR. See "Publishing to a backend"
# in the README for the request/response contract.
# PUBLISH_URL=https://example.com
# PUBLISH_TOKEN=
