# Copy to .env and fill in. .env is gitignored.

# --- Required ---
ANTHROPIC_API_KEY=
TAVILY_API_KEY=            # app.tavily.com — free tier: 1,000 credits/month

# --- Optional ---
# Model used for both the research and writing stages (default below).
# RESEARCH_MODEL=claude-opus-4-8

# Where file-sink drafts are written (default: output/).
# OUTPUT_DIR=output

# IANA timezone for resolving dated prompt files (prompts/YYYY-MM-DD.md).
# PROMPT_TZ=UTC

# --- Optional: publish to an HTTP backend instead of writing files ---
# Set BOTH to POST each finished draft to your own endpoint with a bearer
# token, rather than writing it to OUTPUT_DIR. See "Publishing to a backend"
# in the README for the request/response contract.
# PUBLISH_URL=https://example.com
# PUBLISH_TOKEN=
